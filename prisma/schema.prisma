generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model categorias {
  id             Int        @id @default(autoincrement())
  nome           String     @db.VarChar(50)
  ordem_exibicao Int?       @default(0)
  produtos       produtos[]
}

model clientes {
  id                Int         @id @default(autoincrement())
  nome              String      @db.VarChar(100)
  telefone_whatsapp String      @unique @db.VarChar(20)
  whatsapp_lid      String?     @unique @db.VarChar(40)
  data_aniversario  DateTime?   @db.Date
  bot_tags          Json        @default("[]")
  bot_handoff_active Boolean    @default(false)
  bot_handoff_updated_at DateTime?
  criado_em         DateTime?   @default(now()) @db.Timestamp(6)
  enderecos         enderecos[]
  pedidos           pedidos[]
}

model configuracoes_loja {
  id                            Int      @id @default(autoincrement())
  loja_aberta                   Boolean? @default(true)
  horario_automatico_ativo      Boolean? @default(false)
  horario_funcionamento         Json?
  tempo_entrega_minutos         Int?     @default(40)
  tempo_entrega_max_minutos     Int?     @default(60)
  taxa_entrega_padrao           Decimal? @default(0.00) @db.Decimal(10, 2)
  mensagem_aviso                String?
  whatsapp_ativo                Boolean? @default(false)
  whatsapp_bot_pausado          Boolean? @default(false)
  whatsapp_webhook_url          String?  @db.VarChar(500)
  whatsapp_webhook_secret       String?  @db.VarChar(255)
  whatsapp_mensagem_novo_pedido String?  @db.VarChar(1000)
  whatsapp_mensagem_status      String?  @db.VarChar(1000)
}

model enderecos {
  id          Int       @id @default(autoincrement())
  cliente_id  Int
  rua         String    @db.VarChar(150)
  numero      String    @db.VarChar(20)
  bairro      String    @db.VarChar(100)
  cidade      String?   @db.VarChar(100)
  complemento String?   @db.VarChar(100)
  referencia  String?
  clientes    clientes  @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pedidos     pedidos[]
}

model taxas_entrega_locais {
  id            Int      @id @default(autoincrement())
  bairro        String?  @db.VarChar(100)
  cidade        String?  @db.VarChar(100)
  valor_entrega Decimal  @db.Decimal(10, 2)
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now()) @db.Timestamp(6)
  atualizado_em DateTime @updatedAt @db.Timestamp(6)
}

model itens_pedido {
  id             Int      @id @default(autoincrement())
  pedido_id      Int
  produto_id     Int
  nome_snapshot  String?  @db.VarChar(150)
  quantidade     Int
  preco_unitario Decimal  @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  pedidos        pedidos  @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  produtos       produtos @relation(fields: [produto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model pedidos {
  id                   Int            @id @default(autoincrement())
  cliente_id           Int
  endereco_id          Int?
  valor_itens          Decimal        @db.Decimal(10, 2)
  valor_entrega        Decimal        @default(0.00) @db.Decimal(10, 2)
  valor_total          Decimal        @db.Decimal(10, 2)
  observacoes          String?        @db.VarChar(500)
  metodo_pagamento     String         @db.VarChar(50)
  status_pagamento     String?        @default("pendente") @db.VarChar(50)
  id_transacao_gateway String?        @unique @db.VarChar(255)
  tracking_token       String         @unique @db.VarChar(64)
  asaas_payment_id     String?        @db.VarChar(255)
  pago_em              DateTime?      @db.Timestamp(6)
  expira_em            DateTime?      @db.Timestamp(6)
  status_entrega       String?        @default("pendente") @db.VarChar(50)
  criado_em            DateTime?      @default(now()) @db.Timestamp(6)
  itens_pedido         itens_pedido[]
  auditoria            pedidos_auditoria[]
  webhook_events       asaas_webhook_events[]
  clientes             clientes       @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  enderecos            enderecos?     @relation(fields: [endereco_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model pedidos_auditoria {
  id                        Int      @id @default(autoincrement())
  pedido_id                 Int
  origem                    String   @default("system") @db.VarChar(50)
  ator                      String?  @db.VarChar(120)
  acao                      String   @db.VarChar(80)
  status_pagamento_anterior String?  @db.VarChar(50)
  status_pagamento_atual    String?  @db.VarChar(50)
  status_entrega_anterior   String?  @db.VarChar(50)
  status_entrega_atual      String?  @db.VarChar(50)
  detalhes                  Json?
  criado_em                 DateTime @default(now()) @db.Timestamp(6)
  pedidos                   pedidos  @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([pedido_id, criado_em])
}

model asaas_webhook_events {
  id            Int       @id @default(autoincrement())
  event_id      String    @unique @db.VarChar(255)
  event_name    String    @db.VarChar(120)
  checkout_id   String?   @db.VarChar(255)
  pedido_id     Int?
  payload       Json
  status        String    @default("recebido") @db.VarChar(30)
  tentativas    Int       @default(0)
  ultimo_erro   String?   @db.VarChar(1000)
  recebido_em   DateTime  @default(now()) @db.Timestamp(6)
  processado_em DateTime? @db.Timestamp(6)
  pedidos       pedidos?  @relation(fields: [pedido_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model produtos {
  id           Int            @id @default(autoincrement())
  categoria_id Int
  nome_doce    String         @db.VarChar(100)
  descricao    String?
  preco        Decimal        @db.Decimal(10, 2)
  imagem_url   String?
  estoque_disponivel Int?
  ativo        Boolean?       @default(true)
  itens_pedido itens_pedido[]
  categorias   categorias     @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model usuarios {
  id             Int              @id @default(autoincrement())
  username       String           @unique @db.VarChar(80)
  password_hash  String           @db.VarChar(255)
  role           String           @default("user") @db.VarChar(20)
  ativo          Boolean          @default(true)
  created_by     Int?
  updated_by     Int?
  criado_em      DateTime         @default(now()) @db.Timestamp(6)
  atualizado_em  DateTime         @updatedAt @db.Timestamp(6)
  refresh_tokens refresh_tokens[]
}

model refresh_tokens {
  id          Int       @id @default(autoincrement())
  usuario_id  Int
  token_hash  String    @unique @db.VarChar(255)
  expires_at  DateTime  @db.Timestamp(6)
  revoked_at  DateTime? @db.Timestamp(6)
  criado_em   DateTime  @default(now()) @db.Timestamp(6)
  usuarios    usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

// Broadcast Module Tables
model broadcast_lists {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  campaigns   broadcast_campaigns[]
  members     broadcast_list_members[]
}

model broadcast_list_members {
  id          Int       @id @default(autoincrement())
  list_id     Int
  client_phone String   @db.VarChar(20)
  client_name String?   @db.VarChar(255)
  added_at    DateTime  @default(now()) @db.Timestamp(6)
  lists       broadcast_lists @relation(fields: [list_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([list_id, client_phone])
  @@index([list_id])
}

model broadcast_templates {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  content    String
  created_at DateTime  @default(now()) @db.Timestamp(6)
}

model broadcast_campaigns {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  message        String
  list_id        Int
  status         String    @default("draft") @db.VarChar(20)
  scheduled_at   DateTime?
  started_at     DateTime?
  finished_at    DateTime?
  total_contacts Int       @default(0)
  sent_count     Int       @default(0)
  failed_count   Int       @default(0)
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  lists          broadcast_lists @relation(fields: [list_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  logs           broadcast_logs[]

  @@index([status, scheduled_at])
}

model broadcast_logs {
  id             Int       @id @default(autoincrement())
  campaign_id    Int
  phone          String    @db.VarChar(20)
  client_name    String?   @db.VarChar(255)
  status         String    @default("pending") @db.VarChar(20)
  error_message  String?
  sent_at        DateTime?
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  campaigns      broadcast_campaigns @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaign_id, status])
}

// Flow Builder Tables
model bot_flows {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  trigger_keyword String  @db.VarChar(100)
  flow_json    Json
  canvas_json  Json      @default("{}") @db.Json
  status       String    @default("draft") @db.VarChar(20)
  published_at DateTime?
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  sessions     client_flow_sessions[]

  @@index([status])
  @@index([trigger_keyword])
}

model client_flow_sessions {
  id           Int       @id @default(autoincrement())
  phone        String    @unique @db.VarChar(20)
  flow_id      Int?
  current_node_id String? @db.VarChar(100)
  waiting_for  String?   @db.VarChar(50)
  context_data Json      @default("{}") @db.Json
  last_activity DateTime @default(now()) @db.Timestamp(6)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  flows        bot_flows? @relation(fields: [flow_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([phone])
}
