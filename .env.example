# Ambiente do app
HOST=0.0.0.0
PORT=3000
# URL base interna/legada do app
APP_BASE_URL=http://localhost:3000
# URL publica canônica usada em callbacks e redirecionamentos externos
APP_URL=https://seu-dominio.com

# Banco e sessao
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
JWT_SECRET=troque-por-um-segredo-forte

# Usuarios padrao
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=troque-esta-senha

# Asaas Checkout
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_ACCESS_TOKEN=$aact_hmlg_sua_chave_aqui
ASAAS_WEBHOOK_TOKEN=gere-um-token-forte-aqui
# Override opcional para callbacks do checkout, se precisar ser diferente do APP_URL
ASAAS_APP_BASE_URL=https://seu-dominio.com
ASAAS_USER_AGENT=DonillaAsaasCheckout/1 (sandbox; www.seu-dominio.com)
ASAAS_CHECKOUT_MINUTES_TO_EXPIRE=60

# Aliases legados ainda aceitos pelo backend
# ASAAS_API_KEY=$aact_hmlg_sua_chave_aqui
# ASAAS_WEBHOOK_AUTH_TOKEN=gere-um-token-forte-aqui

# Opcional: sobrescrever retornos do checkout
# ASAAS_CHECKOUT_SUCCESS_URL=https://seu-dominio.com/?checkout_status=success
# ASAAS_CHECKOUT_CANCEL_URL=https://seu-dominio.com/?checkout_status=cancel
# ASAAS_CHECKOUT_EXPIRED_URL=https://seu-dominio.com/?checkout_status=expired
