# Ambiente base do app
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=http://localhost:3000
# URL publica canonica usada em callbacks e redirecionamentos
APP_URL=https://seu-dominio.com

# Banco e autenticacao
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
POSTGRES_DB=donilla
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-por-uma-senha-forte
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Usuarios da aplicacao
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=troque-esta-senha
AUTH_APP_USER=cliente
AUTH_APP_PASSWORD=troque-esta-senha
AUTH_USER=operador
AUTH_PASSWORD=troque-esta-senha

# Integracao WPP
WPP_SERVER_URL=http://wpp-server:21465
WPP_SESSION_NAME=donilla
WPP_SECRET_KEY=troque-por-um-segredo-forte
WPP_WEBHOOK_TOKEN=troque-por-um-token-forte

# Asaas Checkout
# Exemplo abaixo voltado para desenvolvimento local/sandbox.
# Em producao, defina ASAAS_ENVIRONMENT=production e use a credencial prod.
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_ACCESS_TOKEN=$aact_hmlg_sua_chave_aqui
ASAAS_WEBHOOK_TOKEN=gere-um-token-forte-aqui
ASAAS_APP_BASE_URL=https://seu-dominio.com
ASAAS_CHECKOUT_MINUTES_TO_EXPIRE=60
ASAAS_USER_AGENT=DonillaAsaasCheckout/1 (sandbox; www.seu-dominio.com)

# Aliases mais novos aceitos pelo backend e usados no Bitwarden.
# Use estes nomes em producao se quiser evitar os aliases legados acima.
# ASAAS_API_KEY=$aact_hmlg_sua_chave_aqui
# ASAAS_WEBHOOK_AUTH_TOKEN=gere-um-token-forte-aqui

# Opcional: sobrescrever retornos do checkout
# ASAAS_CHECKOUT_SUCCESS_URL=https://seu-dominio.com/?checkout_status=success
# ASAAS_CHECKOUT_CANCEL_URL=https://seu-dominio.com/?checkout_status=cancel
# ASAAS_CHECKOUT_EXPIRED_URL=https://seu-dominio.com/?checkout_status=expired

# Opcionais uteis de runtime
DEBUG_WHATSAPP_BOT=false
# NODE_ENV=production
# ASAAS_REQUEST_TIMEOUT_MS=15000
# MAX_JSON_BODY_BYTES=1048576
# SERVER_REQUEST_TIMEOUT_MS=15000
# SERVER_HEADERS_TIMEOUT_MS=16000
# SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
# SERVER_MAX_REQUESTS_PER_SOCKET=100
# EXPOSE_ERROR_DETAILS=false
# PUBLIC_BASE_URL=https://seu-dominio.com
# PUBLIC_STORE_URL=https://seu-dominio.com
# STORE_PUBLIC_URL=https://seu-dominio.com
# ALLOW_PRIVATE_WEBHOOK_URLS=false
# WPP_BEARER_TOKEN=token-opcional-se-o-proxy-wpp-exigir
# WPP_PUBLIC_WEBHOOK_URL=https://seu-dominio.com/whatsapp/webhook
