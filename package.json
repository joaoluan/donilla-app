{
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "postinstall": "sh ./scripts/run-prisma-command.sh generate",
    "db:check": "sh ./scripts/run-prisma-command.sh db-check",
    "db:pull": "npx prisma db pull",
    "prisma:validate": "sh ./scripts/run-prisma-command.sh validate",
    "prisma:generate": "sh ./scripts/run-prisma-command.sh generate",
    "test": "node --test test/*.test.js",
    "smoke:catalog": "bash ./scripts/run-catalog-smoke.sh",
    "smoke:broadcast": "bash ./scripts/run-broadcast-smoke.sh",
    "smoke:flows": "bash ./scripts/run-flow-builder-smoke.sh",
    "validate:predeploy": "bash ./scripts/run-predeploy-validation.sh"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "pg": "^8.19.0",
    "prisma": "^7.4.1",
    "zod": "^4.3.6"
  }
}
